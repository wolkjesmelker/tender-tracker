{
  "name": "tender-tracker",
  "version": "1.0.0",
  "description": "Aanbestedingen tracker voor Van de Kreeke Groep",
  "repository": {
    "type": "git",
    "url": "https://github.com/wolkjesmelker/tenderscraper.git"
  },
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "electron .",
    "lint": "eslint src/",
    "test:bijlage": "tsx src/main/ai/bijlage-context.selftest.ts",
    "preview": "vite preview",
    "icons": "node scripts/build-icons.cjs",
    "dist": "npm run build && electron-builder --publish never",
    "dist:mac": "npm run build && electron-builder --mac --publish never",
    "dist:win": "npm run build && electron-builder --win --publish never",
    "dist:linux": "npm run build && electron-builder --linux --publish never",
    "dist:release": "npm run build && electron-builder --publish always",
    "release:patch": "npm version patch && npm run dist:mac",
    "release:minor": "npm version minor && npm run dist:mac",
    "release:major": "npm version major && npm run dist:mac",
    "release:publish": "npm run build && electron-builder --mac --publish always",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "better-sqlite3": "^11.7.0",
    "call-bind-apply-helpers": "^1.0.2",
    "cheerio": "^1.0.0",
    "deep-equal": "^2.2.3",
    "docx": "^9.2.0",
    "dunder-proto": "^1.0.1",
    "electron-log": "^5.2.4",
    "electron-updater": "^6.8.3",
    "get-intrinsic": "^1.3.0",
    "get-proto": "^1.0.1",
    "jsonrepair": "^3.13.3",
    "mammoth": "^1.12.0",
    "node-cron": "^3.0.3",
    "pdf-parse": "^1.1.1",
    "pdfmake": "^0.2.15",
    "xlsx": "^0.18.5",
    "xml-formatter": "^3.7.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-progress": "^1.1.1",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@tailwindcss/postcss": "^4.1.4",
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.12.0",
    "@types/node-cron": "^3.0.11",
    "@types/pdf-parse": "^1.1.4",
    "@types/pdfmake": "^0.2.9",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "lucide-react": "^0.474.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.3",
    "recharts": "^2.15.1",
    "sharp": "^0.34.5",
    "sql.js": "^1.14.1",
    "tailwind-merge": "^3.0.1",
    "tailwindcss": "^4.1.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
